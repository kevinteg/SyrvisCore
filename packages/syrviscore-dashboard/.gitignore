# SPA build output is produced in the Docker build stage, never committed.
src/syrviscore_dashboard/static/
frontend/node_modules/
frontend/dist/
*.egg-info/
__pycache__/

# The repo-root .gitignore has a Python `lib/` pattern that would otherwise
# swallow the frontend's src/lib/ (TypeScript). Keep it tracked.
!frontend/src/lib/

