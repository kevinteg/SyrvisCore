#!/bin/sh
# preinst - Pre-installation checks (UNPRIVILEGED)
# POSIX shell compatible

# === Logging Functions ===
SCRIPT_NAME="preinst"
LOG_FILE="/tmp/syrviscore-install.log"

log_msg() {
    LEVEL="$1"
    MSG="$2"
    TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
    LOG_LINE="[$LEVEL] [$TIMESTAMP] [$SCRIPT_NAME] $MSG"
    
    # Write to stdout/stderr
    if [ "$LEVEL" = "ERROR" ]; then
        echo "$LOG_LINE" >&2
    else
        echo "$LOG_LINE"
    fi
    
    # Append to log file
    echo "$LOG_LINE" >> "$LOG_FILE" 2>/dev/null || true
}

log_info() {
    log_msg "INFO" "$1"
}

log_warn() {
    log_msg "WARN" "$1"
}

log_error() {
    log_msg "ERROR" "$1"
}

# === Pre-Installation Checks (Unprivileged) ===
log_info "==================================================================="
log_info "Starting SyrvisCore pre-installation checks (Phase 1)"
log_info "==================================================================="
log_info "Note: Running as unprivileged user (no root access)"
log_info "Note: Docker checks will be performed during Phase 2 setup"
log_info ""

# Log environment
log_info "Environment:"
log_info "  User: $(whoami)"
log_info "  Working directory: $(pwd)"
log_info "  PATH: $PATH"

# Determine the volume the package installs to (from SYNOPKG_PKGDEST,
# e.g. /volume1/@appstore/syrviscore -> /volume1). The old check against
# ${pkgwizard_volume}/docker validated a legacy path this package never
# uses and could hard-fail perfectly valid installs.
PKG_VOLUME="/$(echo "${SYNOPKG_PKGDEST:-/volume1}" | cut -d/ -f2)"
case "$PKG_VOLUME" in
    /volume*) : ;;
    *) PKG_VOLUME="/volume1" ;;
esac

# Check 1: Python 3 available
log_info "[1/4] Checking Python 3 availability..."
if command -v python3 >/dev/null 2>&1; then
    PYTHON_VERSION=$(python3 --version 2>&1 || echo "unknown")
    PYTHON_PATH=$(command -v python3)
    log_info "  Python 3 found: $PYTHON_VERSION"
    log_info "  Python path: $PYTHON_PATH"
else
    log_error "  Python 3 not found"
    log_error "FAILED: Python 3 is required"
    log_error "Solution: Your DSM version may not include Python 3"
    log_info "Detailed logs: $LOG_FILE"
    exit 1
fi

# Check 2: venv/ensurepip available (some DSM python3 builds lack it, which
# would otherwise surface later as a confusing venv/pip error in postinst)
log_info "[2/4] Checking Python venv support..."
if python3 -c "import ensurepip" >/dev/null 2>&1; then
    log_info "  ensurepip available - venv creation will work"
else
    log_error "  Python 3 lacks ensurepip - cannot create virtual environments"
    log_error "FAILED: python3 -m venv would not produce a working pip"
    log_info "Detailed logs: $LOG_FILE"
    exit 1
fi

# Check 3: Docker available (warn only - DSM 7.2+ ships 'Container Manager',
# older DSM ships 'Docker'; the INFO file no longer hard-depends on either
# package name, so we check for the runtime here instead)
log_info "[3/4] Checking container runtime..."
if command -v docker >/dev/null 2>&1; then
    log_info "  docker command found: $(command -v docker)"
else
    log_warn "  docker command not found in PATH"
    log_warn "  Install 'Container Manager' (DSM 7.2+) or 'Docker' (older DSM)"
    log_warn "  from Package Center before running 'syrvis setup'"
fi

# Check 4: Sufficient disk space (500MB minimum) on the package volume
log_info "[4/4] Checking available disk space on ${PKG_VOLUME}..."
if df -P "$PKG_VOLUME" >/dev/null 2>&1; then
    AVAILABLE_KB=$(df -P "$PKG_VOLUME" | tail -1 | awk '{print $4}')
    REQUIRED_KB=512000  # 500MB
    AVAILABLE_MB=$((AVAILABLE_KB / 1024))
    REQUIRED_MB=$((REQUIRED_KB / 1024))

    log_info "  Available space: ${AVAILABLE_MB}MB"
    log_info "  Required space: ${REQUIRED_MB}MB"

    if [ "$AVAILABLE_KB" -lt "$REQUIRED_KB" ]; then
        log_error "  Insufficient disk space"
        log_error "FAILED: Need at least ${REQUIRED_MB}MB, only ${AVAILABLE_MB}MB available"
        log_info "Detailed logs: $LOG_FILE"
        exit 1
    fi
    log_info "  Sufficient disk space available"
else
    log_warn "  Could not check disk space for $PKG_VOLUME"
fi

log_info ""
log_info "==================================================================="
log_info "Pre-installation checks completed successfully (Phase 1)"
log_info "==================================================================="
log_info "✓ Python 3 available (with venv support)"
log_info "✓ Sufficient disk space"
log_info ""
log_info "Next: Installation will proceed"
log_info "After installation, SSH in and run:"
log_info "  1. source /var/packages/syrviscore/target/syrviscore.profile"
log_info "  2. syrvisctl install"
log_info "  3. syrvis setup"
log_info ""
log_info "Detailed logs: $LOG_FILE"

exit 0
