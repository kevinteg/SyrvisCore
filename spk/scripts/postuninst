#!/bin/sh
# postuninst - Post-uninstallation script for SyrvisCore
# POSIX shell compatible
#
# REALITY CHECK: per conf/privilege this script runs as the unprivileged
# package user. It therefore does NOT attempt privileged cleanup (boot hook,
# /usr/local/bin symlink) unless it happens to be running as root — it logs
# exact removal commands instead. It NEVER touches the Docker socket and
# NEVER deletes service data: SYRVIS_HOME (versions, config, data, backups)
# is owned by syrvisctl/syrvis, not by this SPK.

SCRIPT_NAME="postuninst"
LOG_FILE="/tmp/syrviscore-uninstall.log"

log_msg() {
    LEVEL="$1"
    MSG="$2"
    TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
    LOG_LINE="[$LEVEL] [$TIMESTAMP] [$SCRIPT_NAME] $MSG"

    if [ "$LEVEL" = "ERROR" ]; then
        echo "$LOG_LINE" >&2
    else
        echo "$LOG_LINE"
    fi

    echo "$LOG_LINE" >> "$LOG_FILE" 2>/dev/null || true
}

log_info() {
    log_msg "INFO" "$1"
}

log_warn() {
    log_msg "WARN" "$1"
}

log_info "==================================================================="
log_info "SyrvisCore post-uninstallation"
log_info "==================================================================="
log_info "  User: $(whoami) (UID: $(id -u))"

# === SECTION 1: Locate the service installation (handoff from preuninst) ===
INSTALL_DIR=""
if [ -f /tmp/syrviscore_install_dir ]; then
    INSTALL_DIR=$(cat /tmp/syrviscore_install_dir 2>/dev/null)
    rm -f /tmp/syrviscore_install_dir 2>/dev/null || true
fi
# Fallback: scan volumes ourselves
if [ -z "$INSTALL_DIR" ] || [ ! -d "$INSTALL_DIR" ]; then
    INSTALL_DIR=""
    for VOLUME in /volume[0-9]*; do
        if [ -f "${VOLUME}/syrviscore/.syrviscore-manifest.json" ]; then
            INSTALL_DIR="${VOLUME}/syrviscore"
            break
        fi
    done
fi

# === SECTION 2: Privileged cleanup (only possible as root) ===
BOOT_HOOK="/usr/local/etc/rc.d/S99syrviscore.sh"
GLOBAL_SYMLINK="/usr/local/bin/syrvis"

if [ "$(id -u)" -eq 0 ]; then
    log_info "[1/3] Removing privileged system resources..."
    if [ -f "$BOOT_HOOK" ]; then
        rm -f "$BOOT_HOOK" && log_info "  Removed boot hook: $BOOT_HOOK" \
            || log_warn "  Could not remove $BOOT_HOOK"
    else
        log_info "  No boot hook found"
    fi
    if [ -L "$GLOBAL_SYMLINK" ] || [ -f "$GLOBAL_SYMLINK" ]; then
        rm -f "$GLOBAL_SYMLINK" && log_info "  Removed symlink: $GLOBAL_SYMLINK" \
            || log_warn "  Could not remove $GLOBAL_SYMLINK"
    else
        log_info "  No global symlink found"
    fi
else
    log_info "[1/3] Running unprivileged - leaving system resources in place"
    if [ -f "$BOOT_HOOK" ] || [ -L "$GLOBAL_SYMLINK" ]; then
        log_warn "  The following remain and are harmless, but can be removed with:"
        [ -f "$BOOT_HOOK" ] && log_warn "    sudo rm -f $BOOT_HOOK"
        [ -L "$GLOBAL_SYMLINK" ] && log_warn "    sudo rm -f $GLOBAL_SYMLINK"
    fi
fi

# === SECTION 3: Service data is always preserved ===
log_info "[2/3] Service data handling..."
if [ -n "$INSTALL_DIR" ] && [ -d "$INSTALL_DIR" ]; then
    log_info "  Data and configuration preserved at: $INSTALL_DIR"
    # Leave a notice if we can write one (best-effort)
    cat > "$INSTALL_DIR/UNINSTALLED.txt" 2>/dev/null << NOTICE_EOF
The SyrvisCore manager package (SPK) was uninstalled on $(date).

Your service data and configuration have been preserved here:
- versions/          - Installed service versions
- config/            - Configuration (.env, docker-compose.yaml)
- data/              - Traefik certificates, Portainer, Cloudflared data
- backups/           - Backup archives

To reinstall: install the SPK from Package Center, then run
'syrvisctl install' - your data will be detected automatically.

To completely remove all data: rm -rf $INSTALL_DIR
(Docker containers, if still running, can be removed with
'docker rm -f traefik portainer cloudflared'.)

For support: https://github.com/kevinteg/SyrvisCore/issues
NOTICE_EOF
    if [ -f "$INSTALL_DIR/UNINSTALLED.txt" ]; then
        log_info "  Wrote notice: $INSTALL_DIR/UNINSTALLED.txt"
    fi
else
    log_info "  No service installation found"
fi

# === SECTION 4: Temp file cleanup ===
log_info "[3/3] Cleaning up temporary files..."
rm -f /tmp/syrviscore_previous_version 2>/dev/null || true
rm -f /tmp/syrviscore-stop.log 2>/dev/null || true

log_info "==================================================================="
log_info "SyrvisCore uninstallation complete"
log_info "==================================================================="
log_info "Detailed logs: $LOG_FILE"

exit 0
